data/pubmed_extracted.v2.json
data/pubmed_extracted.v3.json

# 计划/规划/审计文档(过程性产物,不入库)
.trae/documents/
.trae/plans/

# 一次性审计 / 验证 / 草稿脚本与笔记(已合并到主流程或临时用)
