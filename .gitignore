# 凭据与本地配置(只留 .env.example 作为模板)
scripts/.env
scripts/.env.qwen.example
!scripts/.env.example

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp

# Office 临时文件
~*.docx
~*.xlsx
~*.pdf

