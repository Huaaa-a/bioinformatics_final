# Biopython Entrez 配置
# 必填:NCBI 要求所有 Entrez 请求附带联系邮箱(任意能收到邮件的地址均可)
ENTREZ_EMAIL=

# 可选:在 https://www.ncbi.nlm.nih.gov/account/settings/ 免费申请
# 提供后请求速率从 3 req/s 提升到 10 req/s
ENTREZ_API_KEY=

# 阿里云千问(Qwen)API 配置
# 在阿里云百炼控制台 https://bailian.console.aliyun.com/ 申请
# OpenAI 兼容接口:https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=

# 默认模型(可选:qwen-turbo / qwen-plus / qwen-max)
QWEN_MODEL=qwen-plus
