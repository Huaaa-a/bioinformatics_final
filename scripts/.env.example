# ====================================================
# Biopython Entrez 配置(PubMed 抓取用)
# ====================================================

# 必填:NCBI 要求所有 Entrez 请求附带联系邮箱
# 任意能收到邮件的地址即可,会在限速时收到通知
ENTREZ_EMAIL=

# 可选:在 https://www.ncbi.nlm.nih.gov/account/settings/ 免费申请
# 提供后请求速率从 3 req/s 提升到 10 req/s
ENTREZ_API_KEY=


# ====================================================
# LLM 配置(OpenRouter 网关,通过 OpenAI 兼容接口调用)
# v5 之前用过 dashscope/Qwen,v5 起统一改用 OpenRouter
# ====================================================

# 必填:在 https://openrouter.ai/keys 申请 API key
# OpenRouter 统一中转 Claude / GPT / Gemini / Qwen / DeepSeek 等模型
OPENROUTER_API_KEY=

# 可选:v3 脚本 (extract_fields_qwen.py) 读这个,没设则用脚本内 DEFAULT_MODEL
# v5 脚本 (extract_per_receptor.py) 通过 CLI 参数 --model 指定,不会读这个
# 任选 OpenRouter 支持的 model id,例如:
#   anthropic/claude-opus-4           (v5 默认,精度高但贵)
#   anthropic/claude-3.5-sonnet       (性价比高)
#   openai/gpt-4o-mini                (便宜,精度略低)
#   qwen/qwen-plus                    (中文友好)
#   google/gemini-2.5-flash           (快且便宜)
OPENROUTER_MODEL=anthropic/claude-opus-4
